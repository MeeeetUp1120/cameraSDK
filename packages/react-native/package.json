{
  "name": "@meeeetup1120/react-native",
  "version": "0.1.0",
  "description": "React Native SDK for meeeetup-cam — Vision Camera + ML Kit face detection",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MeeeetUp1120/cameraSDK.git",
    "directory": "packages/react-native"
  },
  "dependencies": {
    "@meeeetup1120/core": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-native": ">=0.73.0",
    "react-native-vision-camera": ">=4.0.0",
    "@react-native-async-storage/async-storage": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@react-native-async-storage/async-storage": { "optional": false }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-native": "^0.73.0",
    "typescript": "^5.7.2"
  }
}
